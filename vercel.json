{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/verify",
      "dest": "backend/server.js"
    },
    {
      "src": "/",
      "dest": "public/index.html"
    },
    {
      "src": "/([^.]+)$",
      "dest": "public/$1.html"
    },
    {
      "src": "/(.*)",
      "dest": "public/$1"
    }
  ]
}
