{
  "version": 2,
  "builds": [
    {
      "src": "public/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/verify.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/verify",
      "dest": "/api/verify.js"
    },
    {
      "src": "^/$",
      "dest": "/public/index.html"
    },
    {
      "src": "/moderator/(.*)",
      "dest": "/public/moderator/$1"
    },
    {
      "src": "/admin/(.*)",
      "dest": "/public/admin/$1"
    },
    {
      "src": "/(.*\\.(css|js|html|png|jpg|ico))",
      "dest": "/public/$1"
    },
    {
      "src": "/([^.]+)",
      "dest": "/public/$1.html"
    }
  ]
}
